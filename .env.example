DB_DIALECT=
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
JWT_SECRET=

# NODE_ENV defaults to production if not set
# NODE_ENV=development

# SSL (src/db/sequelize.js)
# DB_SSL=true|false (default: true only in production)
# DB_SSL_REJECT_UNAUTHORIZED=true|false (default: true; set false for self-signed certs)

# Sequelize sync (DEV only; don't enable on production/Render)
# DB_SYNC=true enables sync; DB_SYNC_ALTER updates tables; DB_SYNC_FORCE DROPS tables (DATA LOSS)
DB_SYNC=false
DB_SYNC_ALTER=false
DB_SYNC_FORCE=false
