DB_DIALECT=
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
JWT_SECRET=

# Optional DB flags
# DB_SSL=true|false (default: true in production, false in development)
# DB_SSL_REJECT_UNAUTHORIZED=true|false (default: true)

# Development-only: auto-create/update tables from Sequelize models.
# DO NOT set these on production/Render unless you intentionally want schema sync.
# Disabled by default.
DB_SYNC=false
# If DB_SYNC=true you may also use:
DB_SYNC_ALTER=false
DB_SYNC_FORCE=false
